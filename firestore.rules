rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return request.auth.uid == uid; }
    function isAdmin() { return request.auth.token.admin == true; }

    // Referral Codes: all signed-in users can read. Users can create their own.
    match /referralCodes/{code} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // Users: owner reads/creates their own doc; can only update specific non-financial fields
    match /users/{uid} {
      allow read: if isSignedIn() && isOwner(uid);
      allow read: if isSignedIn() && isAdmin();
      allow create: if isSignedIn() && isOwner(uid);
      allow update: if isSignedIn() && isOwner(uid)
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['fullName', 'fcmToken', 'updatedAt', 'streakBonus', 'badgeKeys', 'spinStreak', 'lastSpinDate']);
      allow delete: if false;
    }

    // Wallets: read only by owner. ALL WRITES MUST HAPPEN VIA CLOUD FUNCTIONS.
    match /wallets/{uid} {
      allow read: if isSignedIn() && isOwner(uid);
      allow read: if isSignedIn() && isAdmin();
      allow write: if false;
    }

    // Machine tiers: any signed-in user reads; admin writes
    match /machineTiers/{tierId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // User machines: owner reads. Cloud Functions write.
    match /userMachines/{machineId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow read: if isSignedIn() && isAdmin();
      allow write: if false;
    }

    // Machine fractions: all signed-in users can read listed fractions
    match /machineFractions/{fracId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Transactions: owner reads. Cloud Functions write.
    match /transactions/{txId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow read: if isSignedIn() && isAdmin();
      allow write: if false;
    }

    // M-Pesa Webhook Transactions: Cloud Functions only
    match /mpesa_transactions/{txId} {
      allow read, write: if false; 
    }

    match /verification_attempts/{userId} {
      allow read: if isSignedIn() && isOwner(userId);
      allow write: if false;
    }

    match /depositRequests/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow read: if isSignedIn() && isAdmin();
      allow write: if false;
    }

    match /walletLedger/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow read: if isSignedIn() && isAdmin();
      allow write: if false;
    }

    match /reservedTransactionCodes/{code} {
      allow read, write: if false;
    }

    // Withdrawals: owner reads. Cloud Functions write.
    match /withdrawals/{wdId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow read: if isSignedIn() && isAdmin();
      allow write: if false;
    }

    // Referrals: referrer or referred can read. Cloud Functions write.
    match /referrals/{refId} {
      allow read: if isSignedIn() && (resource.data.referrerId == request.auth.uid || resource.data.referredId == request.auth.uid);
      allow read: if isSignedIn() && isAdmin();
      allow create: if isSignedIn() && request.resource.data.referredId == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update, delete: if false;
    }

    // Payouts: owner reads. Cloud Functions write.
    match /payouts/{payoutId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow read: if isSignedIn() && isAdmin();
      allow write: if false;
    }

    // Spin Prizes: read by all, write by admin
    match /spinPrizes/{prizeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Spin Tickets: owner reads. Cloud Functions write.
    match /spinTickets/{ticketId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow read: if isSignedIn() && isAdmin();
      allow write: if false;
    }

    // Spin History: owner reads. Cloud Functions write.
    match /spinHistory/{spinId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow read: if isSignedIn() && isAdmin();
      allow write: if false;
    }

    // Badges: read by all, write by admin
    match /badges/{badgeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // User Badges: owner reads. Cloud Functions write.
    match /userBadges/{ubId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow read: if isSignedIn() && isAdmin();
      allow write: if false;
    }

    // Notifications: owner reads. Can only mark as read (update 'read' field only).
    match /notifications/{notifId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow read: if isSignedIn() && isAdmin();
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // Streaks: owner reads. Cloud Functions write.
    match /streaks/{uid} {
      allow read: if isSignedIn() && isOwner(uid);
      allow read: if isSignedIn() && isAdmin();
      allow create: if isSignedIn() && isOwner(uid)
        && request.resource.data.currentStreak == 0
        && request.resource.data.longestStreak == 0;
      allow update: if isSignedIn() && isOwner(uid)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['currentStreak', 'longestStreak', 'lastLoginDate']);
      allow delete: if false;
    }

    // Admins: no client access at all
    match /admins/{adminId} {
      allow read, write: if false;
    }

    // Audit log: admin read only. Cloud Functions write.
    match /auditLog/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /adminAuditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /rate_limits/{limitId} {
      allow read, write: if false;
    }
    match /unparsed_sms/{smsId} {
      allow read, write: if false;
    }
  }
}
